# Local .terraform directories (contains provider binaries/modules)
.terraform/
.terraform*

# .tfstate files (can contain secrets in plain text)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Terraform variable files (often contain sensitive data/secrets)
*.tfvars
*.tfvars.json

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files
.terraform.tfstate.lock.info

# Ignore CLI configuration files
.terraformrc
terraform.rc
